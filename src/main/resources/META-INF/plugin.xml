<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.yamanakahirofumi.siren</id>
    <name>siren</name>
    <vendor>mokojarasi</vendor>
    <description><![CDATA[
A Simple Renderer for Mermaid diagrams (Siren).

Key Features:
 - Support for .mermaid and .mmd file formats
 - Integrated Mermaid diagram editor powered by mermaid.js v11.13.0
 - Zoom in/out capability for diagram viewing
 - Simple and lightweight design

Uses mermaid.js (MIT License) - Copyright (c) 2014 - 2025 Knut Sveidqvist
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.intellij.plugins.markdown</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Mermaid"
                  implementationClass="com.github.yamanakahirofumi.siren.MermaidFileType"
                  fieldName="INSTANCE"
                  language="Mermaid"
                  extensions="mermaid;mmd"/>
        <fileEditorProvider implementation="com.github.yamanakahirofumi.siren.editor.MermaidEditorProvider"/>

        <lang.parserDefinition language="Mermaid"
                               implementationClass="com.github.yamanakahirofumi.siren.psi.MermaidParserDefinition"/>
        <completion.contributor language="Mermaid"
                                implementationClass="com.github.yamanakahirofumi.siren.completion.MermaidCompletionContributor"/>
        <lang.commenter language="Mermaid" implementationClass="com.github.yamanakahirofumi.siren.editor.MermaidCommenter"/>
        <lang.braceMatcher language="Mermaid" implementationClass="com.github.yamanakahirofumi.siren.editor.MermaidBraceMatcher"/>
        <lang.syntaxHighlighterFactory language="Mermaid"
                                       implementationClass="com.github.yamanakahirofumi.siren.highlight.MermaidSyntaxHighlighterFactory"/>

        <liveTemplateContext implementation="com.github.yamanakahirofumi.siren.template.MermaidTemplateContextType"/>
        <defaultLiveTemplates file="/liveTemplates/Mermaid.xml"/>
    </extensions>

    <extensions defaultExtensionNs="org.intellij.plugins.markdown">
        <browserPreviewExtensionProvider implementation="com.github.yamanakahirofumi.siren.markdown.MermaidMarkdownPreviewExtensionProvider"/>
    </extensions>
</idea-plugin>
